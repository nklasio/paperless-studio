{
  "name": "paperless-studio",
  "version": "0.2.1",
  "description": "A focused document workspace for paperless-ngx.",
  "private": true,
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nklasio/paperless-studio.git"
  },
  "homepage": "https://github.com/nklasio/paperless-studio#readme",
  "bugs": {
    "url": "https://github.com/nklasio/paperless-studio/issues"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "docs:screenshots": "playwright test --config playwright.screenshots.config.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run format:check && npm run lint && npm run test && npm run typecheck && npm run build"
  },
  "dependencies": {
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.1",
    "tailwindcss": "4.3.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}

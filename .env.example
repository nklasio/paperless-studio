# Use the URL that the Paperless Studio server can reach.
# Local development commonly uses http://localhost:8000.
# Docker Compose commonly uses the Paperless service name, for example
# http://webserver:8000.
PAPERLESS_URL=http://localhost:8000

# Create an API token for a dedicated Paperless user and keep it secret.
PAPERLESS_TOKEN=replace-with-your-api-token

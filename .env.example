# Use the URL that the Paperless Studio server can reach.
# Local development commonly uses http://localhost:8000.
# Docker Compose commonly uses the Paperless service name, for example
# http://webserver:8000.
PAPERLESS_URL=http://localhost:8000

# Create an API token for a dedicated Paperless user and keep it secret.
PAPERLESS_TOKEN=replace-with-your-api-token

# Optional browser-facing URL used by the "Show in Paperless" action.
# This may differ from PAPERLESS_URL inside Docker.
# PAPERLESS_PUBLIC_URL=https://paperless.example.com

# Optional safety limits. Values shown are the defaults.
PAPERLESS_REQUEST_TIMEOUT_MS=15000
PAPERLESS_MAX_UPLOAD_SIZE_MB=100

# Optional tag name used for Studio's review queue.
PAPERLESS_REVIEW_TAG=Needs review

# Optional built-in authentication. Leave all three unset for local demo mode.
# The session secret must contain at least 32 characters.
# PAPERLESS_STUDIO_USERNAME=studio
# PAPERLESS_STUDIO_PASSWORD=replace-with-a-strong-password
# PAPERLESS_STUDIO_SESSION_SECRET=replace-with-at-least-32-random-characters
